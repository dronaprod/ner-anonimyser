# =============================================================================
# Armor Data Anonymizer — copy this file to ".env" in the SAME directory as main.py
# (.env is gitignored; keep secrets only there, never commit .env)
# =============================================================================
# Format: KEY=value  (no "export"; no quotes unless the value contains spaces)
#
# Loaded automatically by: main.py, wsgi/create_app, and `python -m app.pipeline`
# YAML in config/default.yaml still applies for non-secret defaults; use .env for
# secrets, URLs, and anything you want to change per machine without editing YAML.
# =============================================================================

# --- Web / Flask ---
ARMOR_SECRET_KEY=change-me-in-production
ARMOR_PORT=8765
FLASK_DEBUG=0

# --- Optional: subprocess pipeline ---
# ARMOR_PYTHON=/path/to/project/.venv/bin/python
ARMOR_DATA_ROOT=

# --- GLiNER (Hugging Face model id) ---
ARMOR_GLINER_MODEL=knowledgator/gliner-x-large
# ARMOR_GLINER_USE_MODEL_SPLITTER=1
# ARMOR_GLINER_WORDS_SPLITTER=whitespace

# --- Ollama (local NER + anonymisation subprocess) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_NER_MODEL=qwen3.5:4b
OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_NUM_GPU=0

# --- LiteLLM / OpenAI-compatible API (UI comparison + litellm_ner) ---
# Base URL only; append /v1 automatically unless LITELLM_OPENAI_NO_V1=1
LITELLM_OPENAI_BASE_URL=https://llm-alpha.us.secloredev.io
LITELLM_OPENAI_API_KEY=replace-with-your-key
LITELLM_MODEL=openai/gpt-oss-20b
# LITELLM_OPENAI_NO_V1=0

# --- Gunicorn (production) ---
# GUNICORN_BIND=0.0.0.0:8765
# GUNICORN_WORKERS=4
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=3600
# GUNICORN_LOG_LEVEL=info
